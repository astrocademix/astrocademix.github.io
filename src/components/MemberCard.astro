---
interface Props {
  name: string;
  role: string;
  focus: string[];
  bio: string;
  link?: string;
}

const { name, role, focus, bio, link = '#' } = Astro.props;
---
<article class="member-card glass">
  <div style="display:flex; align-items:center; gap:0.9rem; margin-bottom:0.9rem;">
    <div style="width:56px; height:56px; border-radius:999px; background: radial-gradient(circle at 35% 35%, rgba(103,232,249,.9), rgba(56,189,248,.35) 35%, rgba(139,92,246,.25) 68%, rgba(255,255,255,.04)); border:1px solid rgba(175,206,255,.14);"></div>
    <div>
      <h3>{name}</h3>
      <div class="member-role">{role}</div>
    </div>
  </div>
  <p class="section-copy" style="margin:0;">{bio}</p>
  <div class="tag-list">
    {focus.map((item) => <span class="tag">{item}</span>)}
  </div>
  <a class="button-ghost" style="margin-top:1rem;" href={link}>Profile</a>
</article>
