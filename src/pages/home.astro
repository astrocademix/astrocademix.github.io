---
import BaseLayout from '../layouts/BaseLayout.astro';
import StarfieldBackground from '../components/StarfieldBackground.astro';
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
import MemberCard from '../components/MemberCard.astro';
import ThinkingCard from '../components/ThinkingCard.astro';
import { members } from '../data/members';
import { thinkingPosts } from '../data/thinking';
import { site } from '../data/site';

const links = [
  { href: '#about', label: 'About' },
  { href: '#members', label: 'Members' },
  { href: '#thinking', label: 'Thinking' }
];
---
<BaseLayout title={`${site.name} · Home`} description={site.tagline}>
  <StarfieldBackground />
  <NavBar links={links} />

  <main>
    <section id="about" class="section">
      <div class="container dual-grid grid">
        <div>
          <div class="section-kicker">About</div>
          <h1 class="section-title">A club for people who want to think across boundaries.</h1>
          <p class="section-copy">
            AstroCademiX can be a home for reading, building, questioning, and sharing. The tone does not need to feel like a formal institute page. It can feel alive, curious, and open, while still being serious about science.
          </p>
          <p class="section-copy">
            Use this area to describe what the club studies, how it works, what kinds of ideas it values, and how new people can join the conversation.
          </p>
          <div style="display:flex; gap:0.85rem; flex-wrap:wrap; margin-top:1.35rem;">
            <a class="button" href="#members">Meet the members</a>
            <a class="button-ghost" href="#thinking">Read our thinking</a>
          </div>
        </div>

        <aside class="about-card glass">
          <h3>Suggested structure</h3>
          <div class="tag-list">
            <span class="tag">Astronomy</span>
            <span class="tag">Astrophysics</span>
            <span class="tag">ML</span>
            <span class="tag">Interpretability</span>
            <span class="tag">Discovery</span>
          </div>
          <p class="section-copy" style="margin-top: 1rem;">
            You can turn this into a short manifesto, a mission statement, or a compact overview of your themes and current directions.
          </p>
        </aside>
      </div>
    </section>

    <section id="members" class="section">
      <div class="container">
        <div class="section-kicker">Members</div>
        <h2 class="section-title">People who build the club.</h2>
        <p class="section-copy">
          Keep the bios short and human. Three to five lines per person is enough for the first version.
        </p>
        <div class="grid member-grid" style="margin-top: 1.5rem;">
          {members.map((member) => <MemberCard {...member} />)}
        </div>
      </div>
    </section>

    <section id="thinking" class="section">
      <div class="container">
        <div class="section-kicker">Thinking</div>
        <h2 class="section-title">Notes, essays, reading traces, and early ideas.</h2>
        <p class="section-copy">
          This area is designed to feel lighter than a formal blog. It can hold short reflections, technical notes, reading responses, or internal essays.
        </p>
        <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); margin-top:1.5rem;">
          {thinkingPosts.map((post) => (
            <ThinkingCard
              title={post.title}
              summary={post.summary}
              date={post.date}
              tag={post.tag}
              href={`/thinking/${post.slug}`}
            />
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
